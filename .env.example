PORT=3000

# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Neon pooled PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler/DATABASE?sslmode=require
DB_POOL_MAX=5

# Cloudinary values from one product environment and one API-key row
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=mis-dekhli-chinese-dz
MAX_VIDEO_MB=100

# First teacher; created only if the database has no teacher
TEACHER_NAME=Mis Dekhli Teacher
TEACHER_EMAIL=teacher@example.com
TEACHER_PASSWORD=replace-with-a-strong-password
