# Local port (Render supplies PORT automatically)
PORT=3000

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# Neon: copy the pooled PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Cloudinary: copy the API Environment Variable from the Cloudinary dashboard
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_FOLDER=mis-dekhli-chinese-dz
MAX_VIDEO_MB=100

# The first teacher is created automatically when the database is empty
TEACHER_NAME=Mis Dekhli Teacher
TEACHER_EMAIL=teacher@example.com
TEACHER_PASSWORD=replace-with-a-strong-password
